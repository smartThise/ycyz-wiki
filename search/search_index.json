{"config":{"lang":["zh","en"],"separator":"[\\s\\u200b\\u3000\\-\u3001\u3002\uff0c\uff0e\uff1f\uff01\uff1b]+","pipeline":["stemmer"],"fields":{"title":{"boost":1000.0},"text":{"boost":1.0},"tags":{"boost":1000000.0}}},"docs":[{"location":"","title":"\ud83e\udd85 \u6b22\u8fce\u6765\u5230\u94f6\u5ddd\u4e00\u4e2d Wiki","text":"<p>\u94f6\u5ddd\u4e00\u4e2d\u6821\u53cb\u5171\u5efa\u7684\u6821\u56ed\u7ef4\u57fa \u2014\u2014 \u5728\u8fd9\u91cc,\u6211\u4eec\u4e00\u8d77\u8bb0\u5f55\u6821\u56ed\u751f\u5b58\u6307\u5357\u3001\u5b66\u4e60\u7b14\u8bb0\u548c\u90a3\u4e9b\u8ba9\u4eba\u53c8\u54ed\u53c8\u7b11\u7684\u8001\u5e08\u8bed\u5f55\u3002</p> <ul> <li> <p> \u98df\u5728\u6821\u5185</p> <p>\u54ea\u4e2a\u7a97\u53e3\u6700\u5212\u7b97?\u98df\u5802\u963f\u59e8\u51e0\u70b9\u6700\u6e29\u67d4?\u5b66\u957f\u5b66\u59d0\u7528\u8840\u6cea\u603b\u7ed3\u7684\u98df\u5802\u5730\u56fe\u3002</p> <p> \u7ffb\u7ffb\u83dc\u5355</p> </li> <li> <p> \u8001\u5e08\u8bed\u5f55</p> <p>\u90a3\u4e9b\u5e74\u8001\u5e08\u5728\u8bfe\u5802\u4e0a\u91d1\u53e5\u9891\u51fa,\u4e0d\u8bb0\u4e0b\u6765\u592a\u53ef\u60dc\u4e86\u3002</p> <p> \u8fdb\u5165\u6587\u5e93</p> </li> <li> <p> \u4e00\u8d77\u7f16\u8f91</p> <p>\u672c\u7ad9\u5b8c\u5168\u5f00\u6e90,\u4efb\u4f55\u6821\u53cb\u90fd\u53ef\u4ee5\u63d0\u4ea4\u4fee\u6539\u3002\u4e0d\u4f1a\u5199\u4ee3\u7801?\u5f80\u4e0b\u770b\u3002</p> <p> \u67e5\u770b\u4ed3\u5e93</p> </li> </ul>"},{"location":"#_1","title":"\u5982\u4f55\u63d0\u4ea4\u4fee\u6539","text":"<p>\u672c\u7ad9\u6240\u6709\u9875\u9762\u90fd\u6765\u81ea\u6821\u53cb\u8d21\u732e,\u4f60\u4e0d\u9700\u8981\u4efb\u4f55\u7f16\u7a0b\u57fa\u7840,\u53ea\u9700\u8981\u4e00\u4e2a GitHub \u8d26\u53f7\u3002</p>"},{"location":"#_2","title":"\u7b2c\u4e00\u6b65:\u70b9\u51fb\u53f3\u4e0a\u89d2\u7684\"\u94c5\u7b14\"\u56fe\u6807 \u270f\ufe0f","text":"<p>\u5728\u4efb\u610f\u9875\u9762\u7684**\u53f3\u4e0a\u89d2**(\u9876\u90e8\u5bfc\u822a\u680f),\u4f60\u4f1a\u770b\u5230\u4e00\u4e2a\u94c5\u7b14\u56fe\u6807:</p> <pre><code>\u250c\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2510\n\u2502  \u94f6\u5ddd\u4e00\u4e2d Wiki        GitHub \u270f\ufe0f\u2502   \u2190 \u70b9\u51fb\u8fd9\u628a\u94c5\u7b14!\n\u2514\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2518\n</code></pre> <p>\u70b9\u51fb\u5b83,GitHub \u4f1a\u76f4\u63a5\u6253\u5f00**\u5f53\u524d\u8fd9\u4e00\u9875**\u5bf9\u5e94\u7684 Markdown \u6e90\u6587\u4ef6\u7f16\u8f91\u754c\u9762\u3002</p>"},{"location":"#_3","title":"\u7b2c\u4e8c\u6b65:\u5728\u7ebf\u7f16\u8f91","text":"<ol> <li>GitHub \u4f1a\u81ea\u52a8\u8fdb\u5165\u300c\u7f16\u8f91\u6587\u4ef6\u300d\u754c\u9762\u3002</li> <li>\u5728\u7f51\u9875\u7f16\u8f91\u5668\u91cc\u76f4\u63a5\u4fee\u6539\u6587\u5b57(\u5c31\u50cf\u6539 Word \u4e00\u6837)\u3002</li> <li>\u6539\u5b8c\u4e4b\u540e,\u5728\u53f3\u4e0b\u89d2\u586b\u5199\u4e00\u53e5\u8bdd\u8bf4\u660e\u4f60\u6539\u4e86\u4ec0\u4e48(\u4f8b\u5982:\u4fee\u6b63\u4e86\u4e09\u697c\u98df\u5802\u7684\u5f00\u653e\u65f6\u95f4)\u3002</li> <li>\u70b9\u51fb Propose changes(\u63d0\u4ea4\u4fee\u6539\u5efa\u8bae)\u3002</li> </ol>"},{"location":"#pull-request","title":"\u7b2c\u4e09\u6b65:\u63d0\u4ea4 Pull Request","text":"<ol> <li>GitHub \u4f1a\u8ba9\u4f60\u300cCreate pull request\u300d,\u76f4\u63a5\u70b9\u7eff\u8272\u7684 Create pull request \u6309\u94ae\u3002</li> <li>\u7b49\u5f85\u7ef4\u62a4\u8005\u5ba1\u6838\u901a\u8fc7 \u2705 \u540e,\u4f60\u7684\u4fee\u6539\u5c31\u4f1a**\u81ea\u52a8\u90e8\u7f72\u4e0a\u7ebf**!</li> </ol> <p> \u6ca1\u6709\u8d26\u53f7? \u524d\u5f80 github.com \u514d\u8d39\u6ce8\u518c\u4e00\u4e2a\u5373\u53ef\u53c2\u4e0e\u7f16\u8f91\u3002</p>"},{"location":"#_4","title":"\u7ad9\u70b9\u6e90\u7801","text":"<p>\u6574\u4e2a\u7ad9\u70b9\u7684\u6e90\u7801\u6258\u7ba1\u5728 GitHub,\u6b22\u8fce \u2b50Star\u3001\ud83d\udc1b\u63d0Issue\u3001\ud83d\udd01\u63d0PR:</p> <ul> <li>\u4ed3\u5e93\u5730\u5740: GitHub - ycyz-wiki</li> <li>\u95ee\u9898\u53cd\u9988: Issues</li> </ul> <p>\u89c9\u5f97\u672c\u7ad9\u5bf9\u4f60\u6709\u5e2e\u52a9?</p> <p>\u53bb\u4ed3\u5e93\u53f3\u4e0a\u89d2\u70b9\u4e2a \u2b50Star,\u662f\u5bf9\u7ef4\u62a4\u8005\u6700\u5927\u7684\u9f13\u52b1!</p>"},{"location":"#_5","title":"\u52a0\u5165\u6211\u4eec","text":"<ul> <li>\u60f3\u6210\u4e3a\u7ef4\u62a4\u8005?</li> <li>\u60f3\u65b0\u589e\u4e00\u4e2a\u680f\u76ee(\u6bd4\u5982\u300c\u6821\u53cb\u6545\u4e8b\u300d\u300c\u793e\u56e2\u6307\u5357\u300d)?</li> <li>\u53d1\u73b0\u5185\u5bb9\u8fc7\u65f6\u6216\u9519\u8bef?</li> </ul> <p>\u90fd\u6b22\u8fce\u5728 Issues \u91cc\u544a\u8bc9\u6211\u4eec,\u6216\u5728\u4ea4\u6d41\u7fa4\u91cc @\u7ba1\u7406\u5458\u3002</p> <p>\u672c\u7ef4\u57fa\u7531\u94f6\u5ddd\u4e00\u4e2d\u6821\u53cb\u5171\u540c\u7ef4\u62a4 \u00b7 \u5185\u5bb9\u9075\u5faa CC BY-SA 4.0 \u534f\u8bae</p>"},{"location":"%E6%A0%A1%E5%8F%B2/","title":"Index","text":"<p>\u767e\u5eff\u6bcd\u6821\u3002</p>"},{"location":"%E6%A0%A1%E5%9B%AD%E7%94%9F%E5%AD%98%E6%8C%87%E5%8D%97/","title":"\ud83e\udded \u6821\u56ed\u751f\u5b58\u6307\u5357","text":"<p>\u5b66\u957f\u5b66\u59d0\u7528\u8840\u6cea\u6362\u6765\u7684\u6821\u56ed\u751f\u5b58\u7ecf\u9a8c\u3002</p> <p>\u672c\u680f\u76ee\u6536\u5f55\u5728\u6821\u671f\u95f4\u6700\u5b9e\u7528\u7684\u751f\u6d3b\u4fe1\u606f,\u5305\u62ec\u4f46\u4e0d\u9650\u4e8e:</p> <ul> <li>\ud83c\udf71 \u98df\u5802\u653b\u7565(\u54ea\u4e2a\u7a97\u53e3\u597d\u5403\u3001\u6027\u4ef7\u6bd4\u6700\u9ad8)</li> <li>\ud83c\udfe0 \u4f4f\u5bbf\u987b\u77e5</li> <li>\ud83d\ude8c \u51fa\u884c\u4ea4\u901a</li> <li>\ud83d\udcc5 \u91cd\u8981\u65f6\u95f4\u8282\u70b9(\u8003\u8bd5\u5468\u3001\u653e\u5047\u5b89\u6392)</li> </ul> <p>\u8d21\u732e\u4f60\u7684\u7ecf\u9a8c</p> <p>\u53f3\u4e0a\u89d2\u70b9\u51fb \u270f\ufe0f \u94c5\u7b14\u56fe\u6807,\u628a\u4f60\u7684\u72ec\u5bb6\u5fc3\u5f97\u52a0\u8fdb\u6765\u5427!</p>"},{"location":"%E6%A0%A1%E5%9B%AD%E7%94%9F%E5%AD%98%E6%8C%87%E5%8D%97/#_2","title":"\ud83d\udcd1 \u76ee\u5f55","text":"<ul> <li>\u98df\u5728\u6821\u5185</li> </ul>"},{"location":"%E6%A0%A1%E5%9B%AD%E7%94%9F%E5%AD%98%E6%8C%87%E5%8D%97/%E9%A3%9F%E5%9C%A8%E6%A0%A1%E5%86%85/","title":"\ud83c\udf71 \u98df\u5728\u6821\u5185","text":"<p>\u94f6\u5ddd\u4e00\u4e2d\u98df\u5802\u4e0e\u5c31\u9910\u5168\u653b\u7565\u3002</p> <p>\u672c\u6587\u9700\u8981\u4f60\u7684\u8865\u5145</p> <p>\u98df\u5802\u4fe1\u606f\u53d8\u5316\u5f88\u5feb,\u6b22\u8fce\u6821\u53cb\u6301\u7eed\u66f4\u65b0\u3002\u70b9\u51fb\u53f3\u4e0a\u89d2 \u270f\ufe0f \u5373\u53ef\u53c2\u4e0e\u7f16\u8f91\u3002</p>"},{"location":"%E6%A0%A1%E5%9B%AD%E7%94%9F%E5%AD%98%E6%8C%87%E5%8D%97/%E9%A3%9F%E5%9C%A8%E6%A0%A1%E5%86%85/#_2","title":"\u4e00\u3001\u98df\u5802\u6982\u51b5","text":"\u697c\u5c42 \u7279\u8272 \u63a8\u8350\u6307\u6570 \u4e00\u697c \u7ecf\u6d4e\u5957\u9910\u3001\u9762\u98df \u2b50\u2b50\u2b50 \u4e8c\u697c \u5c0f\u7092\u3001\u76d6\u6d47\u996d \u2b50\u2b50\u2b50\u2b50 \u4e09\u697c \u98ce\u5473\u5c0f\u5403 \u2b50\u2b50\u2b50\u2b50\u2b50"},{"location":"%E6%A0%A1%E5%9B%AD%E7%94%9F%E5%AD%98%E6%8C%87%E5%8D%97/%E9%A3%9F%E5%9C%A8%E6%A0%A1%E5%86%85/#_3","title":"\u4e8c\u3001\u63a8\u8350\u7a97\u53e3","text":"<p>\u5b66\u957f\u5b66\u59d0\u63a8\u8350</p> <ul> <li>**\u4e8c\u697c 3 \u53f7\u7a97\u53e3**\u7684\u7ea2\u70e7\u8089\u76d6\u6d47 \u2014\u2014 \u91cf\u8db3\u5473\u6b63</li> <li>**\u4e09\u697c 7 \u53f7\u7a97\u53e3**\u7684\u9ebb\u8fa3\u62cc \u2014\u2014 \u9690\u85cf\u738b\u8005</li> <li>...</li> </ul>"},{"location":"%E6%A0%A1%E5%9B%AD%E7%94%9F%E5%AD%98%E6%8C%87%E5%8D%97/%E9%A3%9F%E5%9C%A8%E6%A0%A1%E5%86%85/#_4","title":"\u4e09\u3001\u5c31\u9910\u65f6\u95f4","text":"<ul> <li>\u65e9\u9910:<code>06:30 - 07:30</code></li> <li>\u5348\u9910:<code>11:30 - 12:30</code></li> <li>\u665a\u9910:<code>17:30 - 18:30</code></li> </ul> <p>\u9ad8\u5cf0\u671f</p> <p>\u4e2d\u5348 12:00 \u524d\u540e\u662f\u4eba\u6d41\u9ad8\u5cf0,\u5efa\u8bae\u63d0\u524d 10 \u5206\u949f\u6